{
  "expo": {
    "name": "Lite Ledger",
    "slug": "lite-ledger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/app/icon/icon.png",
    "scheme": "liteledger",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./src/assets/app/icon/icon.png",
      "bundleIdentifier": "com.anonymous.lite-ledger"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#22C55E",
        "foregroundImage": "./src/assets/app/icon/icon-transparent.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/app/icon/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./src/assets/app/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
